{
  "name": "ship-of-theseus",
  "private": true,
  "version": "0.0.0",
  "description": "Local-first AI character dialogue interface.",
  "author": "",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "cross-env THESEUS_ELECTRON_DEV=1 vite --host 127.0.0.1",
    "electron:dev": "concurrently -k \"npm run dev:web\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "local-ai": "node bridge-server/server.js",
    "build": "vite build",
    "electron:build": "npm run build && electron-builder",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.shipoftheseus.local",
    "productName": "Ship of Theseus",
    "directories": {
      "output": "release-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "bridge-server/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "persona_path.json",
        "to": "persona_path.json"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.195",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
